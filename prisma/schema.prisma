generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model attendance {
  id                   String   @id
  employeeCode         String
  employeeName         String
  branch               String?
  gender               String?
  department           String?
  annualLeaveDays      Float    @default(0)
  paidLeaveDays        Float    @default(0)
  unpaidLeaveDays      Float    @default(0)
  sundayOvertimeHours  Float    @default(0)
  holidayOvertimeHours Float    @default(0)
  weekdayOvertimeHours Float    @default(0)
  month                Int
  year                 Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime

  @@unique([employeeCode, month, year], map: "Attendance_employeeCode_month_year_key")
}

model auditlog {
  id           String   @id @default(cuid())
  tableName    String
  recordId     String
  action       String
  oldData      Json?
  newData      Json?
  changedBy    String
  changeDetail String?
  createdAt    DateTime @default(now())
}

model branch {
  id        String   @id
  code      String   @unique(map: "Branch_code_key")
  name      String   @unique(map: "Branch_name_key")
  address   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model country {
  id        String   @id
  code      String   @unique(map: "Country_code_key")
  name      String   @unique(map: "Country_name_key")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model customer {
  id        String   @id
  code      String   @unique(map: "Customer_code_key")
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model department {
  id        String   @id
  code      String   @unique(map: "Department_code_key")
  name      String   @unique(map: "Department_name_key")
  status    String   @default("ACTIVE")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model dispatchorder {
  id               String          @id
  purchasingPlanId String?
  employeeName     String
  dispatchDate     DateTime
  expectedDate     DateTime
  origin           String
  destination      String
  dispatcher       String
  status           String          @default("PENDING")
  note             String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  purchasingplan   purchasingplan? @relation(fields: [purchasingPlanId], references: [id], map: "DispatchOrder_purchasingPlanId_fkey")

  @@index([purchasingPlanId], map: "DispatchOrder_purchasingPlanId_fkey")
}

model employee {
  id             String    @id
  employeeCode   String    @unique(map: "Employee_employeeCode_key")
  fullName       String
  position       String
  department     String
  branch         String?
  salaryLevel    String?
  phone          String?
  email          String?
  gender         String?
  idCardNumber   String?
  idCardDate     DateTime?
  address        String?
  startDate      DateTime?
  endDate        DateTime?
  status         String    @default("ACTIVE")
  educationLevel String?
  maritalStatus  String?
  workplace      String?
  creator        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
}

model laborcontract {
  id                      String    @id
  employeeName            String
  branch                  String?
  contractNumber          String    @unique(map: "LaborContract_contractNumber_key")
  contractType            String
  contractDate            DateTime
  startDate               DateTime
  endDate                 DateTime?
  position                String
  department              String
  salaryLevel             String?
  salaryBase              Float     @default(0)
  attendanceAllowance     Float     @default(0)
  performanceAllowance    Float     @default(0)
  responsibilityAllowance Float     @default(0)
  attractionAllowance     Float     @default(0)
  positionAllowance       Float     @default(0)
  otherAllowance          Float     @default(0)
  socialInsurance         Float     @default(0)
  createdDate             DateTime  @default(now())
  status                  String    @default("Tạo mới")
  creator                 String
  approver                String?
  note                    String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime
  durationMonths          Int?
}

model leaverequest {
  id           String   @id
  createdAt    DateTime @default(now())
  employeeName String
  branch       String?
  startDate    DateTime
  endDate      DateTime
  totalDays    Int
  reason       String
  status       String   @default("Tạo mới")
  approver     String?
  note         String?
  updatedAt    DateTime
  leaveCode    String?  @unique(map: "LeaveRequest_leaveCode_key")
  subReason    String?
}

model materialplan {
  id         String   @id
  planNumber String   @unique(map: "MaterialPlan_planNumber_key")
  planDate   DateTime @default(now())
  creator    String
  status     String   @default("Tạo mới")
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  order      order[]
}

model notification {
  id         String   @id
  title      String
  message    String
  link       String?
  isRead     Boolean  @default(false)
  type       String?
  targetRole String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

model order {
  id                   String          @id
  orderCode            String          @unique(map: "Order_orderCode_key")
  customerCode         String
  employeeName         String
  orderDate            DateTime        @default(now())
  branch               String?
  requestDeliveryDate  DateTime?
  productionFinishDate DateTime?
  shipDate             DateTime?
  thermometer          Boolean         @default(false)
  status               String          @default("Tạo mới")
  note                 String?
  materialPlanId       String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime
  materialplan         materialplan?   @relation(fields: [materialPlanId], references: [id], map: "Order_materialPlanId_fkey")
  orderitem            orderitem[]
  productionplan       productionplan?
  purchasingplan       purchasingplan?

  @@index([materialPlanId], map: "Order_materialPlanId_fkey")
}

model orderitem {
  id             String   @id
  orderId        String
  productName    String
  packaging      String?
  quantity       Int      @default(0)
  hasPallet      Boolean  @default(false)
  hasCornerGuard Boolean  @default(false)
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  order          order    @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "OrderItem_orderId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
}

model payroll {
  id            String          @id
  month         Int
  year          Int
  branch        String?
  creator       String
  approver      String?
  note          String?
  status        String          @default("Tạo mới")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  payrollCode   String?         @unique(map: "Payroll_payrollCode_key")
  payrolldetail payrolldetail[]

  @@unique([month, year], map: "Payroll_month_year_key")
}

model payrolldetail {
  id                       String   @id
  payrollId                String
  employeeCode             String
  employeeName             String?
  incomePerWorkday         Float    @default(0)
  attendanceBonus          Float    @default(0)
  performanceBonus         Float    @default(0)
  responsibilityBonus      Float    @default(0)
  attractionBonus          Float    @default(0)
  otherBonus               Float    @default(0)
  overtimePay              Float    @default(0)
  socialInsuranceDeduction Float    @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime
  payroll                  payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade, map: "PayrollDetail_payrollId_fkey")

  @@index([payrollId], map: "PayrollDetail_payrollId_fkey")
}

model permission {
  id               String             @id
  code             String             @unique(map: "Permission_code_key")
  name             String             @unique(map: "Permission_name_key")
  status           String             @default("ACTIVE")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  permissiondetail permissiondetail[]
  user             user[]             @relation("permissiontouser")
}

model permissiondetail {
  id           String     @id
  permissionId String
  moduleKey    String
  canAccess    Boolean    @default(false)
  permission   permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, map: "PermissionDetail_permissionId_fkey")

  @@unique([permissionId, moduleKey], map: "PermissionDetail_permissionId_moduleKey_key")
}

model position {
  id        String   @id
  code      String   @unique(map: "Position_code_key")
  name      String   @unique(map: "Position_name_key")
  status    String   @default("ACTIVE")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model product {
  id              String          @id
  code            String          @unique(map: "Product_code_key")
  name            String
  categoryId      String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  note            String?
  status          String          @default("Hoạt động")
  productcategory productcategory @relation(fields: [categoryId], references: [id], map: "Product_categoryId_fkey")
  unit            unit[]          @relation("producttounit")

  @@index([categoryId], map: "Product_categoryId_fkey")
}

model productcategory {
  id          String    @id
  name        String    @unique(map: "ProductCategory_name_key")
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  code        String    @unique(map: "ProductCategory_code_key")
  status      String    @default("Hoạt động")
  product     product[]
}

model productionplan {
  id                 String               @id
  orderId            String               @unique(map: "ProductionPlan_orderId_key")
  status             String               @default("PENDING")
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  order              order                @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "ProductionPlan_orderId_fkey")
  productionplanitem productionplanitem[]
}

model productionplanitem {
  id               String         @id
  productionPlanId String
  product          String
  quantity         Int
  producedQuantity Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  productionplan   productionplan @relation(fields: [productionPlanId], references: [id], onDelete: Cascade, map: "ProductionPlanItem_productionPlanId_fkey")

  @@index([productionPlanId], map: "ProductionPlanItem_productionPlanId_fkey")
}

model purchaseorder {
  id                  String                @id
  poCode              String                @unique(map: "PurchaseOrder_poCode_key")
  creator             String
  branch              String?
  createdDate         DateTime              @default(now())
  requestedDate       DateTime
  purpose             String
  status              String                @default("Tạo mới")
  deliveryLocation    String?
  note                String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  purchaseorderdetail purchaseorderdetail[]
  purchaseinvoice     purchaseinvoice[]
}

model purchaseorderdetail {
  id                String        @id
  purchaseOrderId   String
  productCode       String
  productName       String
  requestedQuantity Float         @default(0)
  deliveryLocation  String?
  note              String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  unit              String?
  purchaseorder     purchaseorder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, map: "PurchaseOrderDetail_purchaseOrderId_fkey")

  @@index([purchaseOrderId], map: "PurchaseOrderDetail_purchaseOrderId_fkey")
}

model purchaseinvoice {
  id                  String                  @id
  invoiceCode         String                  @unique(map: "PurchaseInvoice_invoiceCode_key")
  creator             String
  branch              String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime
  supplier            String
  status              String                  @default("Tạo mới")
  deliveryDate        DateTime
  note                String?
  purchaseOrderId     String?
  poCode              String?
  invoiceType         String                  @default("Nhập kho")
  warehouseName       String?
  purchaseorder       purchaseorder?          @relation(fields: [purchaseOrderId], references: [id])
  purchaseinvoicedetail purchaseinvoicedetail[]
}

model purchaseinvoicedetail {
  id                String          @id
  purchaseInvoiceId String
  productCode       String
  productName       String
  requestedQuantity Float           @default(0)
  purchasedQuantity Float           @default(0)
  deliveryLocation  String?
  unit              String?
  note              String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  purchaseinvoice   purchaseinvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade, map: "PurchaseInvoiceDetail_purchaseInvoiceId_fkey")

  @@index([purchaseInvoiceId], map: "PurchaseInvoiceDetail_purchaseInvoiceId_fkey")
}


model purchasingplan {
  id                 String               @id
  orderId            String               @unique(map: "PurchasingPlan_orderId_key")
  status             String               @default("PENDING")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  dispatchorder      dispatchorder[]
  order              order                @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "PurchasingPlan_orderId_fkey")
  purchasingplanitem purchasingplanitem[]
}

model purchasingplanitem {
  id               String         @id
  purchasingPlanId String
  material         String
  quantity         Int
  unit             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  purchasingplan   purchasingplan @relation(fields: [purchasingPlanId], references: [id], onDelete: Cascade, map: "PurchasingPlanItem_purchasingPlanId_fkey")

  @@index([purchasingPlanId], map: "PurchasingPlanItem_purchasingPlanId_fkey")
}

model resignation {
  id              String   @id
  employeeName    String
  branch          String?
  requestDate     DateTime @default(now())
  resignationDate DateTime
  reason          String
  status          String   @default("Tạo mới")
  approver        String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  resignationCode String?  @unique(map: "Resignation_resignationCode_key")
}

model salarychange {
  id                  String   @id
  requestDate         DateTime @default(now())
  type                String
  isSelf              Boolean  @default(false)
  employeeName        String
  branch              String?
  currentSalaryLevel  String?
  proposedSalaryLevel String
  effectiveMonth      Int
  effectiveYear       Int
  status              String   @default("Tạo mới")
  creator             String
  approver            String?
  reason              String?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  changeCode          String?  @unique(map: "SalaryChange_changeCode_key")
}

model salaryincreaserequest {
  id             String   @id
  createdAt      DateTime @default(now())
  employeeName   String
  currentSalary  Float?
  proposedSalary Float
  reason         String
  status         String   @default("Tạo mới")
  approver       String?
  note           String?
  updatedAt      DateTime
}

model salarylevel {
  id                  String   @id
  stt                 Int
  levelCode           String   @unique(map: "SalaryLevel_levelCode_key")
  baseSalary          Float
  attendanceBonus     Float    @default(0)
  performanceBonus    Float    @default(0)
  responsibilityBonus Float    @default(0)
  attractionBonus     Float    @default(0)
  otherBonus          Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime
}

model supplier {
  id        String   @id
  code      String   @unique(map: "Supplier_code_key")
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model transferpromotion {
  id                 String   @id
  requestDate        DateTime @default(now())
  employeeName       String
  branch             String?
  currentPosition    String
  newPosition        String
  currentDepartment  String
  newDepartment      String
  currentSalaryLevel String?
  newSalaryLevel     String?
  effectiveDate      DateTime
  status             String   @default("Tạo mới")
  creator            String
  note               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
}

model unit {
  id        String    @id
  code      String    @unique(map: "Unit_code_key")
  name      String    @unique(map: "Unit_name_key")
  status    String    @default("Hoạt động")
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  product   product[] @relation("producttounit")
}

model user {
  id           String       @id
  username     String       @unique(map: "User_username_key")
  password     String
  employeeName String?
  employeeId   String?
  branch       String?
  role         String       @default("SALES")
  status       String       @default("ACTIVE")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  permission   permission[] @relation("permissiontouser")
}

model violation {
  id           String   @id
  employeeName String
  branch       String?
  date         DateTime @default(now())
  reason       String
  level        String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model warehouse {
  id        String   @id
  code      String   @unique(map: "Warehouse_code_key")
  name      String   @unique(map: "Warehouse_name_key")
  status    String   @default("Hoạt động")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model warehouselog {
  id            String               @id
  logCode       String               @unique
  logType       String
  creator       String
  createdAt     DateTime             @default(now())
  referenceCode String?
  logDate       DateTime             @default(now())
  subject       String?
  description   String?
  status        String               @default("Đã nhập kho")
  note          String?
  details       warehouselogdetail[]
}

model warehouselogdetail {
  id                String       @id
  warehouseLogId    String
  productCode       String
  productName       String
  unit              String?
  requestedQuantity Float        @default(0)
  actualQuantity    Float        @default(0)
  orderCode         String?
  note              String?
  warehouselog      warehouselog @relation(fields: [warehouseLogId], references: [id], onDelete: Cascade)
}
